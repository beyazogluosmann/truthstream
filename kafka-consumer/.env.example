# TruthStream Kafka Consumer - Environment Variables

# ==========================================
# LLM Provider Seçimi
# ==========================================
# Kullanılacak LLM provider: groq | gemini | anthropic
LLM_PROVIDER=groq

# ==========================================
# Groq API (Llama 3.3 70B)
# ==========================================
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Google Gemini API
# ==========================================
# https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Anthropic Claude API
# ==========================================
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# Google Fact Check API
# ==========================================
# https://console.cloud.google.com/apis/credentials
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key_here

# ==========================================
# News API
# ==========================================
# https://newsapi.org/account
NEWS_API_KEY=your_news_api_key_here

# ==========================================
# Elasticsearch
# ==========================================
ELASTICSEARCH_NODE=http://localhost:9200

# ==========================================
# Kafka
# ==========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=truthstream-consumer
KAFKA_GROUP_ID=news-verification-group
KAFKA_TOPIC=news-claims
